VITE_APP_NAME="Your Blueprint Wellness"
VITE_PUBLIC_DOMAIN="yourblueprintwellness.com"

# Browser-exposed settings. Only VITE_* values are available to frontend code.
VITE_SUPABASE_URL=""
VITE_SUPABASE_ANON_KEY=""
VITE_SUPPORT_EMAIL="support@yourblueprintwellness.com"

# Server-only settings for Supabase Edge Functions.
# Add these with Supabase function secrets, not in Vite/browser env.
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=""
AZURE_DOCUMENT_INTELLIGENCE_KEY=""
AZURE_DOCUMENT_INTELLIGENCE_MODEL_ID="prebuilt-read"

# Do not place real API keys, secrets, or private health data in this file.
# Use public Supabase anon keys only. Never place service-role keys or private secrets in Vite env files.
